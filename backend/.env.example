# Copy to .env and fill in.

# SQLite by default (zero config). For Postgres:
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/ledger
DATABASE_URL=sqlite:///./ledger.db

# Auth
SECRET_KEY=change-me-to-a-long-random-string
APP_PASSWORD=changeme

# Allowed frontend origins (add your Railway URL once deployed)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3007

# Stripe (Phase 3) — from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OCR (Phase 2) — leave empty to use the built-in heuristic parser
OCR_PROVIDER=
# GOOGLE_APPLICATION_CREDENTIALS=./gcp-doc-ai.json
# DOC_AI_PROCESSOR=projects/xxx/locations/us/processors/yyy

# File storage for receipts
UPLOAD_DIR=./uploads

# Default tax set-aside rate for untaxed income (fraction, e.g. 0.30 = 30%)
DEFAULT_TAX_RATE=0.30
